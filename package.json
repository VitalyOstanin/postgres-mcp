{
  "name": "@vitalyostanin/postgres-mcp",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "chmod +x dist/index.js && cp package.json dist/package.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:up": "podman-compose -f compose.yaml up -d",
    "test:integration:down": "podman-compose -f compose.yaml down",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "model-context-protocol",
    "postgres"
  ],
  "author": "Vitaly Ostanin <vitaly.ostanin@mail.ru>",
  "license": "MIT",
  "description": "MCP server for comprehensive PostgreSQL integration: database operations, tables, queries, connection management, monitoring",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "postgres-mcp": "dist/index.js"
  },
  "homepage": "https://github.com/VitalyOstanin/postgres-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VitalyOstanin/postgres-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/VitalyOstanin/postgres-mcp/issues"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.json",
    "README.md",
    "README-ru.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "ip-address": "^10.1.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "luxon": "^3.5.0",
    "pg": "^8.13.0",
    "pg-query-stream": "^4.10.3",
    "pgsql-parser": "^17.8.1",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.12",
    "@types/pg-cursor": "^2.7.2",
    "@types/pg-query-stream": "^1.0.3",
    "@types/yargs": "^17.0.34",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-flat-gitignore": "^2.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
