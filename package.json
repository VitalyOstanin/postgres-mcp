{
  "name": "@vitalyostanin/postgres-mcp",
  "version": "0.5.2",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "chmod +x dist/index.js && cp package.json dist/package.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint/",
    "lint:fix": "eslint . --fix --cache --cache-location node_modules/.cache/eslint/",
    "test": "timeout 600 vitest run",
    "test:watch": "vitest",
    "test:coverage": "timeout 600 vitest run --coverage",
    "test:integration": "timeout 600 vitest run --config vitest.integration.config.ts",
    "test:integration:up": "podman-compose -f compose.yaml up -d",
    "test:integration:down": "podman-compose -f compose.yaml down",
    "format": "npm run --silent lint:fix",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm audit --omit=dev --audit-level=moderate && npm run build"
  },
  "keywords": [
    "model-context-protocol",
    "postgres"
  ],
  "author": "Vitaly Ostanin <vitaly.ostanin@mail.ru>",
  "license": "MIT",
  "description": "MCP server for comprehensive PostgreSQL integration: database operations, tables, queries, connection management, monitoring",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.12.1",
  "bin": {
    "postgres-mcp": "dist/index.js"
  },
  "homepage": "https://github.com/VitalyOstanin/postgres-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VitalyOstanin/postgres-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/VitalyOstanin/postgres-mcp/issues"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.json",
    "README.md",
    "README-ru.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "ip-address": "^10.1.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "luxon": "^3.7.2",
    "pg": "^8.22.0",
    "pg-query-stream": "^4.16.0",
    "pgsql-parser": "^17.9.15",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/pg-cursor": "^2.7.2",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-config-flat-gitignore": "^2.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
